    function seededNoise(x, y, seed = 1337) {
        const s = Math.sin((x * 12.9898 + y * 78.233 + seed) * 43758.5453);
        return s - Math.floor(s);
    }

    function levelToFloodColor(level) {
        if (level === 3) return 'rgba(69, 85, 140, 0.72)';
        if (level === 2) return 'rgba(104, 130, 220, 0.60)';
