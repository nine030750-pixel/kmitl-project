    function drawLabels(activeLocs, depthMap) {
        labelLayers.forEach(l => map.removeLayer(l));
        labelLayers = [];
        if (!showLabels) return;

        activeLocs.forEach(loc => {
            const depth = depthMap[loc.name] || '0.00';
            const color = getRiskColor(depth);
            const icon = L.divIcon({
                className: '',
                html: `<div class="zone-label" style="border-color:${color}22;color:${color};">${loc.name} <b>${depth}ม.</b></div>`,
                iconAnchor: [0, 0]
            });
            const lbl = L.marker([loc.pos[0] + 0.15, loc.pos[1] + 0.1], { icon, interactive: false }).addTo(map);
