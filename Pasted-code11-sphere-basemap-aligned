    function buildThailandFloodMockCells() {
        const cells = [];

        TH_FLOOD_RISK_REGIONS.forEach((region, rIndex) => {
            const startLat = region.lat - (region.rows * region.stepLat) / 2;
            const startLng = region.lng - (region.cols * region.stepLng) / 2;

            for (let row = 0; row < region.rows; row++) {
                for (let col = 0; col < region.cols; col++) {
                    const n = seededNoise(col + rIndex * 10, row + rIndex * 20, 7123);
                    const m = seededNoise(col + 99, row + 77, 8841);

                    const rowBias = 1 - Math.abs((row - region.rows / 2) / (region.rows / 2));
                    const colBias = 1 - Math.abs((col - region.cols / 2) / (region.cols / 2));
                    const centerBias = (rowBias + colBias) / 2;

                    const keepScore = (n * 0.6) + (centerBias * 0.4);
                    if (keepScore < (1 - region.density)) continue;

                    let level = 1;
                    const lv = (m * 0.65) + (centerBias * 0.35);
                    if (lv > 0.78) level = 3;
                    else if (lv > 0.48) level = 2;

                    cells.push({
                        lat: startLat + row * region.stepLat,
                        lng: startLng + col * region.stepLng,
                        stepLat: region.stepLat,
                        stepLng: region.stepLng,
                        level
                    });
                }
            }
        });

        thailandFloodMockCells = cells;
    }

    function latLngToMercatorPixel(lat, lng, zoom) {
        const tileSize = 256;
        const scale = tileSize * Math.pow(2, zoom);

        const x = (lng + 180) / 360 * scale;
        const sinLat = Math.sin(lat * Math.PI / 180);
        const y = (0.5 - Math.log((1 + sinLat) / (1 - sinLat)) / (4 * Math.PI)) * scale;

        return { x, y };
    }

    function renderThailandFloodRiskDom() {
        const layer = document.getElementById('gistdaFloodLayer');
        const sphereEl = document.getElementById('sphereMapBg');

        if (!layer || !sphereEl || !sphereMap || !sphereReady || !useSphereBasemap || !thailandFloodMockEnabled) return;

        if (!thailandFloodMockCells.length) buildThailandFloodMockCells();

        layer.innerHTML = '';
        layer.style.display = 'block';

        const center = sphereMap.location();
        const zoom = sphereMap.zoom();

        if (!center || typeof zoom !== 'number') return;

        const w = sphereEl.clientWidth || window.innerWidth;
        const h = sphereEl.clientHeight || window.innerHeight;
        const centerPx = latLngToMercatorPixel(center.lat, center.lon, zoom);

        thailandFloodMockCells.forEach(cell => {
            const p = latLngToMercatorPixel(cell.lat, cell.lng, zoom);
            const p2 = latLngToMercatorPixel(cell.lat + cell.stepLat, cell.lng + cell.stepLng, zoom);

            const x = (p.x - centerPx.x) + w / 2;
            const y = (p.y - centerPx.y) + h / 2;

            const width = Math.max(4, Math.abs(p2.x - p.x));
            const height = Math.max(4, Math.abs(p2.y - p.y));

            if (x < -60 || y < -60 || x > w + 60 || y > h + 60) return;

            const el = document.createElement('div');
            el.style.position = 'absolute';
            el.style.left = `${x}px`;
            el.style.top = `${y}px`;
            el.style.width = `${width}px`;
            el.style.height = `${height}px`;
            el.style.background = levelToFloodColor(cell.level);
            el.style.border = 'none';
            el.style.pointerEvents = 'none';

            layer.appendChild(el);
        });
    }

