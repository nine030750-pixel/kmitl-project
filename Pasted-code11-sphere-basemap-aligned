    /* ══════════════════════════════════════════
       MAIN UPDATE (เดิม + ขยาย)
    ══════════════════════════════════════════ */
    function updateSimulation() {
        if (isGistdaView) return;

        const rain    = parseInt(document.getElementById('rainSlider').value);
        const slope   = parseInt(document.getElementById('slopeSlider').value);
        const opacity = parseInt(document.getElementById('opacitySlider').value) / 100;
        const selIdx  = document.getElementById('locationSelect').value;

        document.getElementById('rVal').innerText = rain;
        document.getElementById('sVal').innerText = slope;
        document.getElementById('oVal').innerText = Math.round(opacity * 100);

        /* ลบ circles เดิม */
        map.eachLayer(l => { if (l instanceof L.Circle) map.removeLayer(l); });
        impactDotLayers = [];

        const totalGlobalRisk = ((rain / 400) * 7 + (slope / 90) * 3).toFixed(1);

        /* ── แสดงข้อมูลพื้นที่ที่เลือก ── */
        if (selIdx !== 'all') {
            const loc = locations[parseInt(selIdx)];
            const res = calculateRisk(rain, slope, loc);
            const color = getRiskColor(res.depth);
            const pct   = Math.min(Math.round((parseFloat(res.depth) / 4) * 100), 100);

            document.getElementById('areaName').innerText = loc.name + ' · ' + loc.typeLabel;
            document.getElementById('areaRisk').style.color = color;
            document.getElementById('areaRisk').innerHTML = `${res.depth} <small>ม.</small>`;
            document.getElementById('areaRadiusInfo').innerText = `รัศมีผลกระทบ: ${res.radiusKm} กม.`;

            /* risk bar */
            document.getElementById('riskBarWrap').style.display = 'block';
            document.getElementById('riskBarFill').style.width = pct + '%';
            document.getElementById('riskBarFill').style.background = color;
            document.getElementById('riskBarPct').innerText = pct + '%';

            /* mini stats */
            document.getElementById('miniStats').style.display = 'grid';
            document.getElementById('statType').innerText = res.label.split(' ')[0] + ' ' + loc.typeLabel;
            document.getElementById('statRadius').innerText = res.radiusKm + ' กม.';
            document.getElementById('typeLabel').innerText = 'สถานะ: ' + getRiskLevel(res.depth);
            document.getElementById('typeLabel').style.color = color;
        } else {
            document.getElementById('areaName').innerText   = 'ภาพรวมระบบ';
            document.getElementById('areaRisk').innerHTML   = `${totalGlobalRisk} <small>RISK</small>`;
            document.getElementById('areaRisk').style.color = '#fff';
            document.getElementById('areaRadiusInfo').innerText = 'ความเสี่ยงรวมทุกพื้นที่';
            document.getElementById('riskBarWrap').style.display = 'none';
            document.getElementById('miniStats').style.display   = 'none';
            document.getElementById('typeLabel').innerText = 'คลิกจุดใดก็ได้บนแผนที่เพื่อดูความเสี่ยงเฉพาะจุด';
            document.getElementById('typeLabel').style.color = '';
        }

        /* ── วาด circles + collect active locations ── */
        const activeLocs = [];
        const depthMap   = {};

        locations.forEach(loc => {
            if (totalGlobalRisk >= loc.trigger) {
                const res   = calculateRisk(rain, slope, loc);
                const color = getRiskColor(res.depth);

                /* กรอง filter */
                const level = getRiskLevel(res.depth);
                if (activeFilter === 'critical' && level !== 'วิกฤต') return;
                if (activeFilter === 'warning'  && level !== 'เฝ้าระวัง') return;
                if (activeFilter === 'safe'     && level !== 'ปลอดภัย') return;

                L.circle(loc.pos, {
                    color, fillColor: color,
                    fillOpacity: opacity,
                    weight: 1,
                    radius: res.radiusMeters
                }).addTo(map)
                  .bindPopup(buildPopup(loc, res, color));

                activeLocs.push(loc);
                depthMap[loc.name] = res.depth;
            }
        });

        /* impact dots + labels */
        if (activeLocs.length > 0) {
            drawImpactDots(activeLocs, depthMap, opacity);
            drawLabels(activeLocs, depthMap);
        } else {
            labelLayers.forEach(l => map.removeLayer(l));
            labelLayers = [];
        }

        document.getElementById('lastUpdate').innerText = new Date().toLocaleTimeString('th-TH');
    }

    /* ══════════════════════════════════════════
       POPUP BUILDER (ปรับปรุงจากเดิม)
    ══════════════════════════════════════════ */
    function buildPopup(loc, res, color) {
        const level = getRiskLevel(res.depth);
        return `<div class="popup-inner">
            <div class="popup-risk" style="color:${color}">${res.depth} ม.</div>
            <div class="popup-status" style="color:${color}">${level}</div>
            <hr class="popup-divider">
            <div class="popup-detail">
                ${res.label}<br>
                รัศมีผลกระทบ: <b style="color:#fff">${res.radiusKm} กม.</b><br>
                พิกัด: ${loc.pos[0].toFixed(4)}, ${loc.pos[1].toFixed(4)}
            </div>
            <div class="popup-actions">
                <button class="popup-btn" onclick="copyCoords(${loc.pos[0]},${loc.pos[1]})">📋 คัดลอก</button>
                <button class="popup-btn" onclick="openGoogleMaps(${loc.pos[0]},${loc.pos[1]})">🗺 Maps</button>
            </div>
        </div>`;
    }

    /* ══════════════════════════════════════════
       MAP CLICK (เดิม — ปรับ popup ใหม่)
    ══════════════════════════════════════════ */
    map.on('click', function(e) {
        const rain  = parseInt(document.getElementById('rainSlider').value);
        const slope = parseInt(document.getElementById('slopeSlider').value);
        const clat = e.latlng.lat, clng = e.latlng.lng;
        lastClickCoords = { lat: clat, lng: clng };

        const totalGlobalRisk = ((rain / 400) * 7 + (slope / 90) * 3);
        let nearestZone = null, nearestDist = Infinity;
        locations.forEach(loc => {
            if (totalGlobalRisk >= loc.trigger) {
                const d = distKm(clat, clng, loc.pos[0], loc.pos[1]);
                if (d < nearestDist) { nearestDist = d; nearestZone = loc; }
            }
        });

        let pointRisk, status, color, extraInfo;

        if (nearestZone && nearestDist <= 700) {
            const res = calculateRisk(rain, slope, nearestZone);
            const baseDepth = parseFloat(res.depth);
            const attenuation = nearestDist <= 150 ? 1.0
                              : nearestDist <= 400 ? 1.0 - (nearestDist-150)/250*0.55
                              : 1.0 - (nearestDist-150)/550*0.85;
            const adjDepth = (baseDepth * Math.max(attenuation, 0.15)).toFixed(2);

            color     = nearestDist <= 150 ? "#ff4b2b" : nearestDist <= 400 ? "#ffa500" : "#2ecc71";
            status    = nearestDist <= 150 ? "วิกฤต"   : nearestDist <= 400 ? "เตือนภัย" : "ปลอดภัย";
            pointRisk = adjDepth;
            extraInfo = `ใกล้ ${nearestZone.name} ${Math.round(nearestDist)} km`;
        } else {
            const raw = ((rain/400)*1.2 + (slope/90)*0.8).toFixed(2);
            pointRisk = raw; color = "#2ecc71"; status = "ปลอดภัย";
            extraInfo = "ห่างจากพื้นที่เสี่ยง";
        }

        clickPopup
            .setLatLng(e.latlng)
            .setContent(`<div class="popup-inner">
                <div class="popup-risk" style="color:${color}">${pointRisk} ม.</div>
                <div class="popup-status" style="color:${color}">${status}</div>
                <hr class="popup-divider">
                <div class="popup-detail">${extraInfo}</div>
                <div class="popup-coord">${clat.toFixed(5)}, ${clng.toFixed(5)}</div>
                <div class="popup-actions">
                    <button class="popup-btn" onclick="copyCoords(${clat},${clng})">📋 คัดลอก</button>
                    <button class="popup-btn" onclick="openGoogleMaps(${clat},${clng})">🗺 Maps</button>
                </div>
            </div>`)
            .openOn(map);
    });

    /* ══════════════════════════════════════════
       GEOLOCATION (เดิม)
    ══════════════════════════════════════════ */
    function getLocation() {
        if (!navigator.geolocation) { showToast('เบราว์เซอร์ไม่รองรับ GPS'); return; }
        showToast('⏳ กำลังค้นหาตำแหน่ง...');
        navigator.geolocation.getCurrentPosition((pos) => {
            const lat = pos.coords.latitude, lon = pos.coords.longitude;
            if (userMarker) map.removeLayer(userMarker);
            const myIcon = L.divIcon({
                className: '',
                html: `<div style="width:14px;height:14px;background:#00d2ff;border:3px solid #fff;border-radius:50%;box-shadow:0 0 12px #00d2ff;"></div>`,
                iconAnchor: [7,7]
            });
            userMarker = L.marker([lat, lon], { icon: myIcon }).addTo(map)
                .bindPopup(`<div class="popup-inner"><b>📍 ตำแหน่งของคุณ</b><div class="popup-coord">${lat.toFixed(5)}, ${lon.toFixed(5)}</div></div>`).openPopup();
            map.flyTo([lat, lon], 13);
            showToast('📍 พบตำแหน่งของคุณแล้ว');
        }, () => showToast('❌ ไม่สามารถเข้าถึงตำแหน่งได้'));
    }

    /* ══════════════════════════════════════════
       NEW FEATURES
    ══════════════════════════════════════════ */
    function focusArea() {
        const val = document.getElementById('locationSelect').value;
        if (val === 'all') map.flyTo([13.7563, 100.5018], 6);
        else map.flyTo(locations[parseInt(val)].pos, 11);
        updateSimulation();
    }

    function setFilter(type) {
        activeFilter = type;
        ['all','critical','warning','safe'].forEach(f => {
            const el = document.getElementById('chip-'+f);
            el.className = 'chip' + (f === type ? ' active' : '');
        });
        updateSimulation();
    }

    function toggleLabels() {
        showLabels = !showLabels;
        document.getElementById('labelIcon').style.color = showLabels ? '' : 'rgba(255,255,255,0.3)';
        updateSimulation();
        showToast(showLabels ? '🏷 เปิดป้ายกำกับ' : '🏷 ปิดป้ายกำกับ');
    }

    function toggleBasemap() {
        useSatellite = !useSatellite;
        if (useSatellite) {
            map.removeLayer(darkTile); satTile.addTo(map);
            document.getElementById('satelliteBtn').style.color = 'var(--accent)';
            if (useSphereBasemap && sphereMap && sphereReady && window.sphere) {
                try { sphereMap.Layers.setBase(sphere.Layers.HYBRID); } catch (e) {}
            }
            showToast('🛰 Satellite view');
        } else {
            map.removeLayer(satTile); darkTile.addTo(map);
            document.getElementById('satelliteBtn').style.color = '';
            if (useSphereBasemap && sphereMap && sphereReady && window.sphere) {
                try { sphereMap.Layers.setBase(sphere.Layers.STREETS); } catch (e) {}
            }
            showToast('🗺 Dark map view');
        }
    }

    function resetView() {
        map.flyTo([13.7563, 100.5018], 6);
        document.getElementById('locationSelect').value = 'all';
        updateSimulation();
        showToast('🔄 รีเซ็ตมุมมองแล้ว');
    }

    function copyCoords(lat, lng) {
        const text = `${lat.toFixed(5)}, ${lng.toFixed(5)}`;
        navigator.clipboard?.writeText(text).then(() => showToast('📋 คัดลอกพิกัดแล้ว: ' + text))
            .catch(() => showToast('พิกัด: ' + text));
    }

    function openGoogleMaps(lat, lng) {
        window.open(`https://www.google.com/maps?q=${lat},${lng}`, '_blank');
    }

    function exportCoords() {
        const rain  = document.getElementById('rainSlider').value;
        const slope = document.getElementById('slopeSlider').value;
        const url   = `${location.origin}${location.pathname}?rain=${rain}&slope=${slope}`;
        navigator.clipboard?.writeText(url).then(() => showToast('🔗 คัดลอก link แล้ว'))
            .catch(() => showToast('🔗 ' + url));
    }

    /* ── Load params from URL (ถ้ามี) ── */
    (function loadURLParams() {
        const p = new URLSearchParams(location.search);
        if (p.get('rain'))  { document.getElementById('rainSlider').value  = p.get('rain');  }
        if (p.get('slope')) { document.getElementById('slopeSlider').value = p.get('slope'); }
        /* sync ค่าไปยัง analysis ด้วย */
        localStorage.setItem('rainSlider',  document.getElementById('rainSlider').value);
        localStorage.setItem('slopeSlider', document.getElementById('slopeSlider').value);
    })();

    /* ── Sync localStorage เมื่อ slider เปลี่ยน ── */
    document.getElementById('rainSlider').addEventListener('input', function() {
        localStorage.setItem('rainSlider', this.value);
        updateSimulation();
    });
    document.getElementById('slopeSlider').addEventListener('input', function() {
        localStorage.setItem('slopeSlider', this.value);
        updateSimulation();
    });
    document.getElementById('opacitySlider').addEventListener('input', updateSimulation);

    /* ── INIT ── */
    (function initGistdaPanel() {
        const saved = getSavedGistdaKey();
        const input = document.getElementById('gistdaApiKey');
        if (input && saved) input.value = saved;
        setGistdaStatus(saved
            ? 'สถานะ: พบ API key ที่บันทึกไว้ — กดใช้ basemap GISTDA ได้ทันที'
            : 'สถานะ: ยังไม่ได้เชื่อม Sphere basemap');
    })();

    bindLeafletSyncEvents();
    updateSimulation();
    </script>
</body>
</html>
