    function initSphereMapWithKey(key) {
        return new Promise((resolve, reject) => {
            const sphereEl = document.getElementById('sphereMapBg');

            function bootSphere() {
                try {
                    if (!window.sphere) {
                        reject(new Error('window.sphere ไม่พร้อมใช้งาน'));
                        return;
                    }

                    sphereEl.innerHTML = '';
                    sphereEl.style.display = 'block';
                    sphereEl.style.visibility = 'visible';
                    sphereEl.style.pointerEvents = 'none';
                    sphereEl.style.opacity = '1';

                    sphereMap = new window.sphere.Map({
                        placeholder: sphereEl,
                        location: {
                            lon: map.getCenter().lng,
                            lat: map.getCenter().lat
                        },
                        zoom: map.getZoom(),
                        lastView: false,
                        language: 'th'
                    });

                    try { sphereMap.Ui.clear(); } catch (e) {}
                    try { sphereMap.Layers.setBase(window.sphere.Layers.STREETS); } catch (e) {}

                    sphereReady = true;

                    console.log('sphereReady =', sphereReady);
                    console.log('sphereMap exists =', !!sphereMap);
                    console.log('sphereEl children =', sphereEl.children.length);

                    try {
                        if (sphereMap.Event && window.sphere.EventName) {
                            const ev = window.sphere.EventName;
                            sphereMap.Event.bind(ev.Location, function () {
                                if (useSphereBasemap) renderThailandFloodRiskDom();
                            });
                            sphereMap.Event.bind(ev.Zoom, function () {
                                if (useSphereBasemap) renderThailandFloodRiskDom();
                            });
                        }
                    } catch (e) {}

                    resolve();
                } catch (err) {
                    reject(err);
                }
            }

            if (window.sphere) {
                console.log('Sphere already exists');
                bootSphere();
                return;
            }

            const oldScript = document.getElementById('sphereScript');
            if (oldScript) oldScript.remove();

            const script = document.createElement('script');
            script.id = 'sphereScript';
            script.src = `https://api.sphere.gistda.or.th/map/?key=${encodeURIComponent(key)}&t=${Date.now()}`;
            script.async = true;

            const timeout = setTimeout(() => {
                reject(new Error('โหลด Sphere script timeout'));
            }, 10000);

            script.onload = () => {
                clearTimeout(timeout);
                console.log('Sphere script loaded');
                bootSphere();
            };

            script.onerror = () => {
                clearTimeout(timeout);
                console.error('Sphere script failed');
                reject(new Error('โหลด Sphere script ไม่สำเร็จ'));
            };

            document.body.appendChild(script);
        });
    }

