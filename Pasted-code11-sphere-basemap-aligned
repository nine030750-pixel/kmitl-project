    function distKm(lat1, lng1, lat2, lng2) {
        const R = 6371, dLat = (lat2-lat1)*Math.PI/180, dLng = (lng2-lng1)*Math.PI/180;
        const a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLng/2)**2;
        return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
    }

    function calculateRisk(rain, slope, loc) {
        let mult = 1.0, label = "";
        switch(loc.type) {
            case 'urban':    mult = 1.6; label = "🏙️ เมือง (น้ำขัง)";   break;
            case 'lowland':  mult = 1.4; label = "🌾 ที่ราบ (น้ำหลาก)"; break;
            case 'basin':    mult = 1.3; label = "🌊 แอ่งน้ำ (น้ำล้น)"; break;
            case 'mountain': mult = (slope > 30) ? 2.1 : 1.1; label = "⛰️ พื้นที่สูง (น้ำป่า)"; break;
        }
        const depth = (rain * mult) / 85;
        const radiusValue = 8000 + (depth * 12000);
        return { depth: depth.toFixed(2), label, radiusMeters: radiusValue, radiusKm: (radiusValue/1000).toFixed(2) };
    }

    function getRiskColor(depth) {
        return parseFloat(depth) > 1.5 ? "#ff4b2b" : (parseFloat(depth) > 0.5 ? "#ffa500" : "#2ecc71");
    }

    function getRiskLevel(depth) {
        return parseFloat(depth) > 1.5 ? "วิกฤต" : (parseFloat(depth) > 0.5 ? "เฝ้าระวัง" : "ปลอดภัย");
    }

