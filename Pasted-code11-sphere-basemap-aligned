    function randomDotsInRing(centerLat, centerLng, r1km, r2km, count) {
        const dots = [];
        for (let i = 0; i < count; i++) {
            const r   = Math.sqrt(Math.random() * (r2km*r2km - r1km*r1km) + r1km*r1km);
            const ang = Math.random() * 2 * Math.PI;
            const dlat = kmToLat(r) * Math.sin(ang);
            const dlng = kmToLng(r, centerLat) * Math.cos(ang);
            dots.push([centerLat + dlat, centerLng + dlng]);
        }
        return dots;
    }

    /* ══════════════════════════════════════════
       IMPACT DOTS (เดิม — คงไว้ทุกอย่าง)
    ══════════════════════════════════════════ */
    function drawImpactDots(activeLocations, depthMap, baseOpacity) {
        impactDotLayers.forEach(l => map.removeLayer(l));
        impactDotLayers = [];

        activeLocations.forEach(loc => {
            const depth = parseFloat(depthMap[loc.name]) || 0.1;
            const innerCount = Math.round(18 + depth * 22);
            const midCount   = Math.round(28 + depth * 18);
            const outerCount = Math.round(22 + depth * 10);
            const [clat, clng] = loc.pos;

            const rings = [
                { dots: randomDotsInRing(clat, clng, 0,   150, innerCount), color: '#ff4b2b', minR: 1400, maxR: 2200, opFactor: [0.4, 0.3] },
                { dots: randomDotsInRing(clat, clng, 150, 400, midCount),   color: '#ffa500', minR: 1200, maxR: 2800, opFactor: [0.25, 0.25] },
                { dots: randomDotsInRing(clat, clng, 400, 700, outerCount), color: '#2ecc71', minR: 1400, maxR: 3200, opFactor: [0.15, 0.2] },
            ];

            /* ── apply filter ── */
            const filterMap = { critical: 0, warning: 1, safe: 2 };
            const allowedRings = activeFilter === 'all' ? [0,1,2] : [filterMap[activeFilter]];

            rings.forEach((ring, idx) => {
                if (!allowedRings.includes(idx)) return;
                ring.dots.forEach(pos => {
                    const r = Math.random() * (ring.maxR - ring.minR) + ring.minR;
                    const layer = L.circle(pos, {
                        radius: r, color: ring.color, fillColor: ring.color,
                        fillOpacity: baseOpacity * (ring.opFactor[0] + Math.random() * ring.opFactor[1]),
                        weight: 0, interactive: false
                    }).addTo(map);
                    impactDotLayers.push(layer);
                });
            });
        });
    }

    /* ══════════════════════════════════════════
