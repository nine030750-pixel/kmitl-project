<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>THE SENTINEL - Login</title>
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Kanit', sans-serif; }
        body {
            height: 100vh; display: flex; justify-content: center; align-items: center;
            background: url('1-1-1.jpg.webp') no-repeat center center/cover;
            background-color: #0a0e17;
        }
        .login-card {
            width: 400px; padding: 50px 40px;
            background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 30px;
            text-align: center; color: #fff; box-shadow: 0 25px 50px rgba(0,0,0,0.3);
        }
        h2 { font-weight: 300; letter-spacing: 4px; margin-bottom: 30px; text-transform: uppercase; }
        .input-group { margin-bottom: 20px; }
        .input-group input {
            width: 100%; padding: 15px 25px; background: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 50px; color: #fff; outline: none;
        }
        .btn-login {
            width: 100%; padding: 15px; border: none; border-radius: 50px;
            background: #00e5ff; color: #000; font-weight: bold; cursor: pointer; transition: 0.3s;
        }
        .social-section { margin-top: 40px; }
        .social-icons { display: flex; justify-content: center; gap: 20px; margin-top: 15px; }
        .social-icons button {
            width: 50px; height: 50px; border-radius: 50%; border: 1px solid rgba(255, 255, 255, 0.3);
            background: rgba(255, 255, 255, 0.1); color: #fff; font-size: 1.5rem; cursor: pointer;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <h2>THE SENTINEL</h2>
        <form id="loginForm">
            <div class="input-group"><input type="text" placeholder="ชื่อผู้ใช้งาน" required></div>
            <div class="input-group"><input type="password" placeholder="รหัสผ่าน" required></div>
            <button type="submit" class="btn-login">เข้าสู่ระบบ</button>
        </form>
        <div class="social-section">
            <p>หรือเชื่อมต่อผ่าน</p>
            <div class="social-icons">
                <button onclick="loginFB()"><i class="fab fa-facebook-f"></i></button>
                <button onclick="loginGoogle()"><i class="fab fa-google"></i></button>
                <button onclick="loginIG()"><i class="fab fa-instagram"></i></button>
            </div>
        </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getAuth, signInWithPopup, GoogleAuthProvider, FacebookAuthProvider } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";

        // *** ใส่ Firebase Config จริงของคุณตรงนี้ ***
        const firebaseConfig = { apiKey: "YOUR_API_KEY", authDomain: "YOUR_PROJECT.firebaseapp.com", projectId: "YOUR_PROJECT", storageBucket: "YOUR_PROJECT.appspot.com", messagingSenderId: "ID", appId: "APP_ID" };
        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);

        const goToHub = () => {
            localStorage.setItem('sentinelLoggedIn', 'true');
            window.location.href = "น้ำท่วม1.html";
        };

        if (localStorage.getItem('sentinelLoggedIn') === 'true') {
            window.location.href = "น้ำท่วม1.html";
        }

        window.loginGoogle = () => {
            const provider = new GoogleAuthProvider();
            signInWithPopup(auth, provider).then(goToHub).catch(err => alert(err.message));
        };
        window.loginFB = () => {
            const provider = new FacebookAuthProvider();
            signInWithPopup(auth, provider).then(goToHub).catch(err => alert(err.message));
        };
        window.loginIG = () => goToHub();

        document.getElementById('loginForm').onsubmit = (e) => { e.preventDefault(); goToHub(); };
    </script>
</body>
</html>
